# Resend — lead capture for the contact form (server-side only, see api/lead.ts).
# Create a key at https://resend.com/api-keys and set these in the Vercel
# dashboard (Project → Settings → Environment Variables). NEVER prefix with
# VITE_ — that would expose the key in the client bundle.
RESEND_API_KEY=

# Inbox that receives lead notifications. Defaults to help@aetherml.com.
LEAD_TO=help@aetherml.com

# Sender address. Must be on a domain you've verified in Resend
# (https://resend.com/domains). Defaults to "Æther Studio <leads@aetherml.com>".
LEAD_FROM="Æther Studio <leads@aetherml.com>"

# WhatsApp number for the co-primary "Message us on WhatsApp" CTAs (hero +
# contact section). Digits only, full international format, no + / spaces / dashes
# (e.g. "5213312345678" for a Guadalajara mobile). Public link, hence VITE_.
# When unset or too short, the WhatsApp CTAs don't render — no broken link ships.
VITE_WHATSAPP_NUMBER=

# Cal.com booking link for the "Book a call" tab in the contact section.
# Format is "username/event-type" (e.g. "aether-studio/audit") — NOT a full URL.
# Create a free account + event type at https://cal.com, then set this. Safe to
# expose in the client bundle (it's a public scheduling link), hence the VITE_
# prefix. When unset, the contact section falls back to the message form only.
VITE_CAL_LINK=

# Cal.com webhook secret — sends the same branded Resend emails on a booking as
# the contact form does (see api/cal-webhook.ts). In Cal.com go to Settings →
# Developer → Webhooks, add a webhook with:
#   Subscriber URL : https://aetherml.com/api/cal-webhook
#   Event trigger  : Booking Created
#   Secret         : any random string — paste the SAME value here.
# Server-side only — NEVER prefix with VITE_. When unset, the endpoint is
# disabled and bookings fall back to Cal.com's own default emails.
CAL_WEBHOOK_SECRET=
