# Resend — lead capture for the contact form (server-side only, see api/lead.ts).
# Create a key at https://resend.com/api-keys and set these in the Vercel
# dashboard (Project → Settings → Environment Variables). NEVER prefix with
# VITE_ — that would expose the key in the client bundle.
RESEND_API_KEY=

# Inbox that receives lead notifications. Defaults to help@aetherml.com.
LEAD_TO=help@aetherml.com

# Sender address. Must be on a domain you've verified in Resend
# (https://resend.com/domains). Defaults to "Æther Studio <leads@aetherml.com>".
LEAD_FROM="Æther Studio <leads@aetherml.com>"

# WhatsApp number for the co-primary "Message us on WhatsApp" CTAs (hero +
# contact section). Digits only, full international format, no + / spaces / dashes
# (e.g. "5213312345678" for a Guadalajara mobile). Public link, hence VITE_.
# When unset or too short, the WhatsApp CTAs don't render — no broken link ships.
VITE_WHATSAPP_NUMBER=

# Calendly — powers the native "Book a call" tab (api/availability.ts + api/book.ts).
# Both are SERVER-SIDE only; NEVER prefix with VITE_ — the browser talks to our
# proxies, never to Calendly directly.
#
# CALENDLY_TOKEN — a Calendly personal access token (paid plan), scopes
#   event_types:read + scheduled_events:write. Create at
#   https://calendly.com/integrations/api_webhooks
CALENDLY_TOKEN=
# CALENDLY_EVENT_TYPE — the event type URI for the 20-min audit call, e.g.
#   https://api.calendly.com/event_types/XXXXXXXX
CALENDLY_EVENT_TYPE=

# Optional client gate (src/lib/scheduling.ts). Defaults ON; set to "false" to
# hide the Book tab and fall back to the message form (e.g. before Calendly is
# wired up). Public, hence the VITE_ prefix.
VITE_SCHEDULING_ENABLED=
