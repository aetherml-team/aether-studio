# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Set to "1" when running behind a reverse proxy (nginx, Caddy, DO load balancer).
# This lets Express trust the X-Forwarded-For / X-Forwarded-Proto headers.
TRUST_PROXY=0

# ── Client build paths ────────────────────────────────────────────────────────
# These are resolved relative to the REPO ROOT (the folder above server/).
# Do NOT use ../ prefixes — the server adds that automatically.
# Defaults below match the standard layout — only uncomment if you moved things.
# LANDING_DIST=landing-page/dist
# APP_DIST=app/dist

# ── AI chatbot (routes/chat.ts) ───────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── CRM integration (routes/crm.ts) ──────────────────────────────────────────
# Generic webhook (Zapier, Make, n8n, etc.)
# CRM_WEBHOOK_URL=https://hooks.zapier.com/...

# HubSpot
# HUBSPOT_PORTAL_ID=
# HUBSPOT_FORM_ID=

# Salesforce
# SF_LOGIN_URL=https://login.salesforce.com
# SF_USERNAME=
# SF_PASSWORD=
# SF_SECURITY_TOKEN=
